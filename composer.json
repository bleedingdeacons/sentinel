{
    "name": "bleeding-deacons/sentinel",
    "description": "Dashboard monitoring widget for the Integrity REST API bridge plugin",
    "type": "wordpress-plugin",
    "license": "MIT (Modified)",
    "authors": [
        {
            "name": "The Bleeding Deacons",
            "email": "thebleedingdeacons@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "10up/wp_mock": "^1.0",
        "mockery/mockery": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^9.6|^10.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Sentinel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sentinel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": "php build.php build:production",
        "build:production": "php build.php build:production",
        "build:dev": "php build.php build:dev",
        "build:clean": "php build.php clean",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
